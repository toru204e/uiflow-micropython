msgstr "常量"

#: ../../source/chain/mono.rst:18 c0057e5da23a4379894cf2a2aadefbf8
msgid "Display modes use ``MonoChain.MODE_PIXEL`` and ``MonoChain.MODE_SCROLL``."
msgstr "显示模式使用 ``MonoChain.MODE_PIXEL`` 和 ``MonoChain.MODE_SCROLL``。"

#: ../../source/chain/mono.rst:20 2bb1397c82ef4a7aa7805a8ada9a26bc
msgid ""
"Scroll directions use ``MonoChain.SCROLL_DIR_LEFT``, "
"``MonoChain.SCROLL_DIR_RIGHT``, ``MonoChain.SCROLL_DIR_UP``, and "
"``MonoChain.SCROLL_DIR_DOWN``."
msgstr ""
"滚动方向使用 "
"``MonoChain.SCROLL_DIR_LEFT``、``MonoChain.SCROLL_DIR_RIGHT``、``MonoChain.SCROLL_DIR_UP``"
" 和 ``MonoChain.SCROLL_DIR_DOWN``。"

#: ../../source/chain/mono.rst:24 c57e1facd09646078eaeb1d6e8cfed1a
msgid ""
"Scroll modes use ``MonoChain.SCROLL_MODE_ONCE``, "
"``MonoChain.SCROLL_MODE_LOOP``, and ``MonoChain.SCROLL_MODE_BOUNCE``."
msgstr ""
"滚动模式使用 ``MonoChain.SCROLL_MODE_ONCE``、``MonoChain.SCROLL_MODE_LOOP`` 和 "
"``MonoChain.SCROLL_MODE_BOUNCE``。"

#: ../../source/chain/mono.rst:27 36d348f016ff4ffe8ea13231b4106c45
msgid ""
"Scroll states use ``MonoChain.SCROLL_STATE_START``, "
"``MonoChain.SCROLL_STATE_PAUSE``, and ``MonoChain.SCROLL_STATE_RESET``."
msgstr ""
"滚动状态使用 ``MonoChain.SCROLL_STATE_START``、``MonoChain.SCROLL_STATE_PAUSE`` "
"和 ``MonoChain.SCROLL_STATE_RESET``。"

#: ../../source/chain/mono.rst:30 2bb1397c82ef4a7aa7805a8ada9a26bc
msgid ""
"Display rotation uses ``MonoChain.ROTATION_0``, "
"``MonoChain.ROTATION_90``, ``MonoChain.ROTATION_180``, and "
"``MonoChain.ROTATION_270``."
msgstr ""
"显示旋转使用 "
"``MonoChain.ROTATION_0``、``MonoChain.ROTATION_90``、``MonoChain.ROTATION_180``"
" 和 ``MonoChain.ROTATION_270``。"

