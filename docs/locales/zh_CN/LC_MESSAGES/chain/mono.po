msgid "Constants"
msgstr "常量"

#: ../../source/chain/mono.rst:18 e37480ec7eaa412ab0c7dd5df9abe010
msgid "Display modes use ``MonoChain.MODE_PIXEL`` and ``MonoChain.MODE_SCROLL``."
msgstr "显示模式使用 ``MonoChain.MODE_PIXEL`` 和 ``MonoChain.MODE_SCROLL``。"

#: ../../source/chain/mono.rst:20 d1dbe6b6b342490db182017589b3aa8f
msgid ""
"Scroll directions use ``MonoChain.SCROLL_DIR_LEFT``, "
"``MonoChain.SCROLL_DIR_RIGHT``, ``MonoChain.SCROLL_DIR_UP``, and "
"``MonoChain.SCROLL_DIR_DOWN``."
msgstr "滚动方向使用 ``MonoChain.SCROLL_DIR_LEFT``、``MonoChain.SCROLL_DIR_RIGHT``、``MonoChain.SCROLL_DIR_UP`` 和 ``MonoChain.SCROLL_DIR_DOWN``。"

#: ../../source/chain/mono.rst:24 b3e3a8179b914db5ad9271898494233e
msgid ""
"Scroll modes use ``MonoChain.SCROLL_MODE_ONCE``, "
"``MonoChain.SCROLL_MODE_LOOP``, and ``MonoChain.SCROLL_MODE_BOUNCE``."
msgstr "滚动模式使用 ``MonoChain.SCROLL_MODE_ONCE``、``MonoChain.SCROLL_MODE_LOOP`` 和 ``MonoChain.SCROLL_MODE_BOUNCE``。"

#: ../../source/chain/mono.rst:27 4c4e74b8c0a041d796738662a4473319
msgid ""
"Scroll states use ``MonoChain.SCROLL_STATE_START``, "
"``MonoChain.SCROLL_STATE_PAUSE``, and ``MonoChain.SCROLL_STATE_RESET``."
msgstr "滚动状态使用 ``MonoChain.SCROLL_STATE_START``、``MonoChain.SCROLL_STATE_PAUSE`` 和 ``MonoChain.SCROLL_STATE_RESET``。"

#: ../../source/chain/mono.rst:30 948568454d1844d3ae682f71f05c2b90
msgid ""
"Display rotation uses ``MonoChain.ROTATION_0``, "
"``MonoChain.ROTATION_90``, ``MonoChain.ROTATION_180``, and "
"``MonoChain.ROTATION_270``."
msgstr "显示旋转使用 ``MonoChain.ROTATION_0``、``MonoChain.ROTATION_90``、``MonoChain.ROTATION_180`` 和 ``MonoChain.ROTATION_270``。"

#: ../../source/chain/mono.rst:34 a954f7aae62944228ad0f4bc45dcc68c
