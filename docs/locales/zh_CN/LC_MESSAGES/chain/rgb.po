msgid "Constants"
msgstr "常量"

#: ../../source/chain/rgb.rst:19 97b662d9c8d04b4aa448a430959d70ce
msgid "Display modes use ``RGBChain.MODE_PIXEL`` and ``RGBChain.MODE_SCROLL``."
msgstr "显示模式使用 ``RGBChain.MODE_PIXEL`` 和 ``RGBChain.MODE_SCROLL``。"

#: ../../source/chain/rgb.rst:21 93963e5cb5d947928206734a8272d80a
msgid ""
"Scroll directions use ``RGBChain.SCROLL_DIR_LEFT``, "
"``RGBChain.SCROLL_DIR_RIGHT``, ``RGBChain.SCROLL_DIR_UP``, and "
"``RGBChain.SCROLL_DIR_DOWN``."
msgstr ""
"滚动方向使用 "
"``RGBChain.SCROLL_DIR_LEFT``、``RGBChain.SCROLL_DIR_RIGHT``、``RGBChain.SCROLL_DIR_UP``"
" 和 ``RGBChain.SCROLL_DIR_DOWN``。"

#: ../../source/chain/rgb.rst:25 82d93df3732244c5ba7feed8aa234109
msgid ""
"Scroll modes use ``RGBChain.SCROLL_MODE_ONCE``, "
"``RGBChain.SCROLL_MODE_LOOP``, and ``RGBChain.SCROLL_MODE_BOUNCE``."
msgstr ""
"滚动模式使用 ``RGBChain.SCROLL_MODE_ONCE``、``RGBChain.SCROLL_MODE_LOOP`` 和 "
"``RGBChain.SCROLL_MODE_BOUNCE``。"

#: ../../source/chain/rgb.rst:28 a54f038f3273430d9e39ba1539072329
msgid ""
"Scroll states use ``RGBChain.SCROLL_STATE_START``, "
"``RGBChain.SCROLL_STATE_PAUSE``, and ``RGBChain.SCROLL_STATE_RESET``."
msgstr ""
"滚动状态使用 ``RGBChain.SCROLL_STATE_START``、``RGBChain.SCROLL_STATE_PAUSE`` 和 "
"``RGBChain.SCROLL_STATE_RESET``。"

#: ../../source/chain/rgb.rst:31 a7e0683e1ee14df7b7fc86fa1bd83b59
msgid ""
"Display rotation uses ``RGBChain.ROTATION_0``, ``RGBChain.ROTATION_90``, "
"``RGBChain.ROTATION_180``, and ``RGBChain.ROTATION_270``."
msgstr ""
"显示旋转使用 "
"``RGBChain.ROTATION_0``、``RGBChain.ROTATION_90``、``RGBChain.ROTATION_180``"
" 和 ``RGBChain.ROTATION_270``。"

